---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
import { BentoGrid, BentoCard } from '../components/ui/BentoGrid.tsx';
import HeroCard from '../components/cards/HeroCard.tsx';
import CinemaCard from '../components/cards/CinemaCard.tsx';
import AboutCard from '../components/cards/AboutCard.tsx';
import SkillsCard from '../components/cards/SkillsCard.tsx';
import CVCard from '../components/cards/CVCard.tsx';
import ProjectsCard from '../components/cards/ProjectsCard.tsx';
import ContactCard from '../components/cards/ContactCard.tsx';
import ScrollToTop from '../components/ScrollToTop.tsx';
---

<Layout title="Jesús Pastor Ricoy | Portfolio Web">
	<!-- Sticky Header -->
	<header class="sticky top-0 z-40 w-full border-b border-border/40 bg-background/55 backdrop-blur-md transition-colors duration-300">
		<div class="max-w-7xl mx-auto px-4 md:px-6 h-16 flex items-center justify-between">
			<a href="#hero" class="font-display font-bold text-lg md:text-xl tracking-tight hover:text-primary transition-colors select-none">
				Jesús Pastor <span class="text-primary">Ricoy</span>
			</a>
			
			<div class="flex items-center gap-5">
				<nav class="hidden sm:flex items-center gap-6 text-sm font-medium text-muted-foreground">
					<a href="#about" class="hover:text-foreground transition-colors">Sobre mí</a>
					<a href="#trajectory" class="hover:text-foreground transition-colors">Trayectoria</a>
					<a href="#projects" class="hover:text-foreground transition-colors">Proyectos</a>
					<a href="#contact" class="hover:text-foreground transition-colors">Contacto</a>
				</nav>
				<ThemeToggle client:load />
			</div>
		</div>
	</header>

	<main class="w-full flex-grow flex flex-col items-center justify-center max-w-7xl mx-auto w-full px-4">
		<!-- Bento Grid Container -->
		<BentoGrid client:load className="pt-4 md:pt-6 pb-12 md:pb-16 gap-4 md:gap-5">
			<!-- Hero Card -->
			<BentoCard id="hero" className="col-span-1 md:col-span-3 lg:col-span-3 min-h-[340px] md:min-h-[300px]" gradient="from-violet-500 via-purple-500 to-transparent" delay={0.0} client:load>
				<HeroCard client:load />
			</BentoCard>

			<!-- Cinema Recommendation Card (Toque de ingenio humano) -->
			<BentoCard className="col-span-1 md:col-span-1 lg:col-span-1 min-h-[340px] md:min-h-[300px]" gradient="from-rose-500 via-pink-500 to-transparent" delay={0.1} client:load>
				<CinemaCard client:load />
			</BentoCard>

			<!-- About Card -->
			<BentoCard id="about" className="col-span-1 md:col-span-2 lg:col-span-2 min-h-[280px]" gradient="from-indigo-500 via-blue-500 to-transparent" delay={0.2} client:load>
				<AboutCard client:load />
			</BentoCard>

			<!-- Skills Card -->
			<BentoCard className="col-span-1 md:col-span-2 lg:col-span-2 min-h-[280px]" gradient="from-emerald-500 via-teal-500 to-transparent" delay={0.3} client:load>
				<SkillsCard client:load />
			</BentoCard>

			<!-- CV Timeline Card -->
			<BentoCard id="trajectory" className="col-span-1 md:col-span-3 lg:col-span-4 min-h-[360px]" gradient="from-amber-500 via-orange-500 to-transparent" delay={0.4} client:load>
				<CVCard client:load />
			</BentoCard>

			<!-- Projects Card -->
			<BentoCard id="projects" className="col-span-1 md:col-span-3 lg:col-span-4 min-h-[360px]" gradient="from-blue-500 via-cyan-500 to-transparent" delay={0.5} client:load>
				<ProjectsCard client:load />
			</BentoCard>

			<!-- Contact Form Card -->
			<BentoCard id="contact" className="col-span-1 md:col-span-3 lg:col-span-4 min-h-[200px]" gradient="from-violet-500 via-indigo-500 to-transparent" delay={0.6} client:load>
				<ContactCard client:load />
			</BentoCard>
		</BentoGrid>
	</main>

	<!-- Footer -->
	<footer class="border-t border-border/40 py-8 bg-card/25 backdrop-blur-sm transition-colors duration-300">
		<div class="max-w-7xl mx-auto px-4 md:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground">
			<p>
				&copy; {new Date().getFullYear()} <span class="font-semibold text-foreground">Jesús Pastor Ricoy</span>. Todos los derechos reservados.
			</p>
			<div class="flex items-center gap-6">
				<a 
					href="https://github.com/JesusPastor96/JPRLandingPage" 
					target="_blank" 
					rel="noopener noreferrer" 
					class="flex items-center gap-1.5 hover:text-foreground transition-colors"
				>
					<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
						<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
					</svg>
					<span>Código fuente</span>
				</a>
				<a href="#about" class="hover:text-foreground transition-colors">Sobre mí</a>
				<a href="#contact" class="hover:text-foreground transition-colors">Contacto</a>
			</div>
		</div>
	</footer>
	<ScrollToTop client:load />
</Layout>
