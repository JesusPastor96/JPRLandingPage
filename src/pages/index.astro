---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
import ScrollToTop from '../components/ScrollToTop.tsx';
import LanguageSelector from '../components/LanguageSelector.tsx';

import Header from '../components/Header.astro';
import Experience from '../components/Experience.astro';
import ProjectsList from '../components/ProjectsList.astro';
import About from '../components/About.astro';
import Interests from '../components/Interests.tsx';
import ContactForm from '../components/ContactForm.tsx';
---

<Layout title="Jesús Pastor Ricoy | Portfolio Web">
	<!-- Sticky Header -->
	<header class="sticky top-0 z-40 w-full border-b border-border/40 bg-background/80 backdrop-blur-md transition-colors duration-300">
		<div class="max-w-4xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
			<a href="#" class="font-display font-bold text-xl tracking-tighter hover:scale-105 transition-transform select-none flex items-center">
				<span class="text-primary mr-0.5">&lt;</span>JPR<span class="text-primary ml-0.5">/&gt;</span>
			</a>
			
			<div class="flex items-center gap-5">
				<nav class="hidden sm:flex items-center gap-6 text-sm font-medium text-muted-foreground">
					<a href="#experience" class="hover:text-foreground transition-colors" data-i18n="nav.experience">Experiencia</a>
					<a href="#projects" class="hover:text-foreground transition-colors" data-i18n="nav.projects">Proyectos</a>
					<a href="#about" class="hover:text-foreground transition-colors" data-i18n="nav.about">Sobre mí</a>
					<a href="#contact" class="hover:text-foreground transition-colors" data-i18n="nav.contact">Contacto</a>
				</nav>
				<div class="flex items-center gap-4">
					<ThemeToggle client:load />
					<LanguageSelector client:load />
				</div>
			</div>
		</div>
	</header>

	<main class="w-full flex-grow flex flex-col max-w-4xl mx-auto px-4 md:px-8 pb-16">
		<Header />
		
		<div id="experience" class="scroll-mt-20">
			<Experience />
		</div>
		
		<div id="projects" class="scroll-mt-20">
			<ProjectsList />
		</div>

		<div id="about" class="scroll-mt-20 py-10">
			<About />
		</div>

		<div id="interests" class="scroll-mt-20">
			<Interests client:visible />
		</div>

		<div id="contact" class="scroll-mt-20">
			<ContactForm client:visible />
		</div>
	</main>

	<!-- Footer -->
	<footer class="border-t border-border/40 py-8 bg-card/10 transition-colors duration-300">
		<div class="max-w-4xl mx-auto px-4 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground">
			<p>
				&copy; {new Date().getFullYear()} <span class="font-semibold text-foreground">Jesús Pastor Ricoy</span>. <span data-i18n="footer.rights">Todos los derechos reservados.</span>
			</p>
			<div class="flex items-center gap-6">
				<a 
					href="https://github.com/JesusPastor96/JPRLandingPage" 
					target="_blank" 
					rel="noopener noreferrer" 
					class="flex items-center gap-1.5 hover:text-foreground transition-colors"
				>
					<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
						<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
					</svg>
					<span data-i18n="footer.source">Código fuente</span>
				</a>
			</div>
		</div>
	</footer>
	<ScrollToTop client:load />
</Layout>
