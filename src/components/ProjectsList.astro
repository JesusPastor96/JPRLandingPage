---
import { Github, MonitorPlay } from 'lucide-react';

const projects = [
  {
    title: "TeamPlate (TFG)",
    tech: [
      { name: "Spring Boot 3", color: "bg-emerald-600 text-white" },
      { name: "Angular", color: "bg-red-600 text-white" },
      { name: "PostgreSQL", color: "bg-sky-600 text-white" },
      { name: "Docker", color: "bg-blue-500 text-white" }
    ],
    githubBE: "https://github.com/JesusPastor96/TFG_BE",
    githubFE: "https://github.com/JesusPastor96/TFG_FE",
    demo: null,
    longDesc: "Plataforma web integral diseñada para digitalizar la operativa del sector hostelero (HORECA). El backend está desarrollado en Spring Boot 3 con Java 21, utilizando seguridad JWT, persistencia mediante JPA/Hibernate y base de datos PostgreSQL ejecutada en Docker. El frontend está maquetado en Angular, implementando vistas para empleados y dueños con control de accesos basado en roles."
  },
  {
    title: "Bailes de Salón (El Reto)",
    tech: [
      { name: "Java", color: "bg-red-500 text-white" },
      { name: "TypeScript", color: "bg-blue-500 text-white" },
      { name: "SQL", color: "bg-emerald-500 text-white" }
    ],
    githubBE: "https://github.com/sofiaffernandez/Reto",
    githubFE: "https://github.com/assxavi/retoFrontend",
    demo: "https://reto.alvaropj.com/",
    longDesc: "Aplicación completa para la gestión y reserva de clases de bailes de salón. Proyecto colaborativo estructurado en una arquitectura desacoplada con la lógica del servidor en Java y la interfaz de usuario en TypeScript, facilitando un flujo dinámico de reservas en tiempo real y gestión de usuarios."
  },
  {
    title: "LandingPage",
    tech: [
      { name: "HTML", color: "bg-orange-500 text-white" },
      { name: "CSS", color: "bg-blue-500 text-white" },
      { name: "GitHub", color: "bg-zinc-800 text-white" }
    ],
    github: "https://github.com/JesusPastor96/LandingPage",
    demo: "https://jesuspastor96.github.io/JPRLandingPage",
    longDesc: "Diseño y maquetación de una web personal completa con páginas interconectadas para Currículum Vitae, Quién soy, Proyectos y Contacto. Totalmente optimizada para visualización móvil y de tablets mediante media queries personalizadas."
  },
  {
    title: "eSports Tournament",
    tech: [
      { name: "UML", color: "bg-indigo-500 text-white" },
      { name: "MVC", color: "bg-purple-500 text-white" },
      { name: "GitHub", color: "bg-zinc-800 text-white" }
    ],
    github: "https://github.com/JesusPastor96/Actividad3-JesusPastorRicoy",
    demo: null,
    longDesc: "Un análisis arquitectónico exhaustivo para una plataforma de torneos de videojuegos de competición. Incluye diagramas de clases, diagramas de casos de uso y la especificación detallada del flujo de control aplicando el patrón de diseño Modelo-Vista-Controlador."
  }
];
---

<section class="py-10 border-b border-border/40">
  <h3 class="text-2xl font-display font-bold text-foreground mb-8 reveal" data-i18n="projects.title">Proyectos Destacados</h3>
  <div class="space-y-12">
    {projects.map((project, index) => (
      <div class="flex flex-col md:flex-row md:gap-8 group hover:bg-muted/20 hover:-translate-y-1 hover:shadow-lg p-5 -mx-5 rounded-2xl transition-all duration-300 reveal delay-100 border border-transparent hover:border-border/50">
        <div class="md:w-1/4 shrink-0 mb-3 md:mb-0">
          <h4 class="text-lg font-bold text-foreground">{project.title}</h4>
        </div>
        <div class="md:w-3/4 flex flex-col justify-between">
          <p class="text-base text-muted-foreground leading-relaxed mb-4" data-i18n={`projects.items.${index}.longDesc`}>
            {project.longDesc}
          </p>
          
          <div class="flex flex-wrap gap-2 mb-5">
            {project.tech.map((t) => (
              <span class={`font-bold rounded-full px-3 py-1 text-xs select-none ${t.color}`}>
                {t.name}
              </span>
            ))}
          </div>

          <div class="flex items-center gap-5 text-sm font-semibold">
            {project.demo && (
              <a href={project.demo} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-primary hover:underline transition-all">
                <MonitorPlay class="w-4 h-4" /> <span data-i18n="projects.viewDemo">Ver demo</span>
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors">
                <Github class="w-4 h-4" /> <span data-i18n="projects.viewGithub">Ver en GitHub</span>
              </a>
            )}
            {project.githubBE && (
              <a href={project.githubBE} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors">
                <Github class="w-4 h-4" /> <span data-i18n="projects.viewGithubBE">GitHub (Backend)</span>
              </a>
            )}
            {project.githubFE && (
              <a href={project.githubFE} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors">
                <Github class="w-4 h-4" /> <span data-i18n="projects.viewGithubFE">GitHub (Frontend)</span>
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
